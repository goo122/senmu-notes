---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import KeyboardShortcuts from '../components/KeyboardShortcuts.astro';
import { site } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  showProgress?: boolean;
}

const {
  title = site.title,
  description = site.description,
  image,
  type = 'website',
  jsonLd,
  showProgress = false,
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} · ${site.name}`;
const base = Astro.site ?? new URL(site.url);
const canonical = new URL(Astro.url.pathname, base).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const ogImage = image ? new URL(image, base).toString() : undefined;

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  name: pageTitle,
  description,
  url: canonical,
  inLanguage: site.lang,
  author: {
    '@type': 'Person',
    name: site.author,
  },
  ...(type === 'website'
    ? {
        potentialAction: {
          '@type': 'SearchAction',
          target: `${base.origin}/search?q={search_term_string}`,
          'query-input': 'required name=search_term_string',
        },
      }
    : {}),
};

const structured = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var key = 'senmu-theme';
          var stored = localStorage.getItem(key);
          var dark =
            stored === 'dark' ||
            ((stored !== 'light') &&
              window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');
          document.documentElement.dataset.theme =
            stored === 'dark' || stored === 'light' ? stored : 'system';
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <script type="application/ld+json" set:html={JSON.stringify(structured)} />
  </head>
  <body class="layout-body">
    {showProgress && <slot name="progress" />}
    <Header currentPath={currentPath} />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <KeyboardShortcuts />
  </body>
</html>

<style>
  .layout-body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .site-main {
    flex: 1;
    padding: var(--space-6) 0 var(--space-8);
    animation: fade-in 0.35s ease both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media print {
    .site-main {
      animation: none;
      padding: 0;
    }

    :global(.site-header),
    :global(.site-footer),
    :global(.back-top),
    :global(.reading-progress),
    :global(.share-bar),
    :global(.comments),
    :global(.related),
    :global(.post-nav) {
      display: none !important;
    }
  }
</style>
