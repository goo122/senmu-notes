---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import KeyboardShortcuts from '../components/KeyboardShortcuts.astro';
import { site } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  showProgress?: boolean;
  /** OG image path, absolute URL, or leave empty for default /og/default */
  ogSlug?: string;
}

const {
  title = site.title,
  description = site.description,
  image,
  type = 'website',
  jsonLd,
  showProgress = false,
  ogSlug = 'default',
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} · ${site.name}`;
const base = Astro.site ?? new URL(site.url);
const canonical = new URL(Astro.url.pathname, base).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const ogImage = image
  ? new URL(image, base).toString()
  : new URL(`/og/${ogSlug}`, base).toString();

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  name: pageTitle,
  description,
  url: canonical,
  inLanguage: site.lang,
  author: {
    '@type': 'Person',
    name: site.author,
  },
  ...(type === 'website'
    ? {
        potentialAction: {
          '@type': 'SearchAction',
          target: `${base.origin}/search?q={search_term_string}`,
          'query-input': 'required name=search_term_string',
        },
      }
    : {}),
};

const structured = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        var key = 'senmu-theme';
        var root = document.documentElement;

        function resolve(theme) {
          if (theme === 'dark' || theme === 'light') return theme;
          return window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        }

        function apply(theme) {
          var resolved = resolve(theme);
          root.classList.toggle('dark', resolved === 'dark');
          root.dataset.theme =
            theme === 'dark' || theme === 'light' ? theme : 'system';
          root.style.colorScheme = resolved;
          document.querySelectorAll('#theme-toggle, .theme-toggle').forEach(function (btn) {
            btn.setAttribute(
              'aria-label',
              resolved === 'dark' ? '切换为浅色模式' : '切换为深色模式',
            );
            btn.setAttribute('aria-pressed', resolved === 'dark' ? 'true' : 'false');
          });
        }

        window.__senmuApplyTheme = apply;

        try {
          var stored = localStorage.getItem(key);
          apply(stored || 'system');
        } catch (e) {
          apply('system');
        }

        // 只注册一次：事件委托，换页后按钮仍可用（修复文章页无法切换主题）
        if (!window.__senmuThemeBound) {
          window.__senmuThemeBound = true;

          document.addEventListener(
            'click',
            function (e) {
              var btn = e.target && e.target.closest && e.target.closest('#theme-toggle, .theme-toggle');
              if (!btn) return;
              e.preventDefault();
              e.stopPropagation();
              var next = root.classList.contains('dark') ? 'light' : 'dark';
              try {
                localStorage.setItem(key, next);
              } catch (err) {}
              apply(next);
            },
            true,
          );

          document.addEventListener('astro:page-load', function () {
            try {
              apply(localStorage.getItem(key) || 'system');
            } catch (err) {
              apply('system');
            }
          });

          document.addEventListener('astro:after-swap', function () {
            try {
              apply(localStorage.getItem(key) || 'system');
            } catch (err) {
              apply('system');
            }
          });

          window
            .matchMedia('(prefers-color-scheme: dark)')
            .addEventListener('change', function () {
              try {
                if (!localStorage.getItem(key)) apply('system');
              } catch (err) {}
            });
        }
      })();
    </script>
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <script type="application/ld+json" set:html={JSON.stringify(structured)} />
  </head>
  <body class="layout-body">
    {showProgress && <slot name="progress" />}
    <Header currentPath={currentPath} />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <KeyboardShortcuts />
  </body>
</html>

<style>
  .layout-body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .site-main {
    flex: 1;
    padding: var(--space-6) 0 var(--space-8);
    animation: fade-in 0.35s ease both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media print {
    .site-main {
      animation: none;
      padding: 0;
    }

    :global(.site-header),
    :global(.site-footer),
    :global(.back-top),
    :global(.reading-progress),
    :global(.share-bar),
    :global(.comments),
    :global(.related),
    :global(.post-nav) {
      display: none !important;
    }
  }
</style>
