---
import type { Heading } from '../lib/reading';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const show = headings.length >= 2;
---

{
  show && (
    <div class="toc-root" data-toc-root>
      <div class="toc-panel" id="toc-panel" data-toc-panel>
        <div class="toc-head">
          <p class="toc-title">目录</p>
          <button
            type="button"
            class="toc-hide-btn"
            data-toc-hide
            aria-controls="toc-panel"
            title="隐藏目录"
          >
            隐藏
          </button>
        </div>
        <nav class="toc" aria-label="文章目录">
          <ol class="toc-list">
            {headings.map((h) => (
              <li class:list={['toc-item', `depth-${h.depth}`]}>
                <a href={`#${h.id}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </div>

      <button
        type="button"
        class="toc-show-btn"
        data-toc-show
        aria-controls="toc-panel"
        title="显示目录"
        hidden
      >
        显示目录
      </button>
    </div>
  )
}

<script is:inline>
  (function () {
    var STORAGE_KEY = 'senmu-toc-hidden';
    var HOST_ID = 'senmu-toc-fixed-host';

    function getArticle() {
      return document.querySelector('article.article.has-toc');
    }

    /** 挂到 body，避免父级 transform / 滚动容器导致 fixed 失效 */
    function ensureHost() {
      var host = document.getElementById(HOST_ID);
      if (!host) {
        host = document.createElement('div');
        host.id = HOST_ID;
        host.setAttribute('data-toc-fixed-host', '');
        document.body.appendChild(host);
      }
      return host;
    }

    function mountFixedUi() {
      var root = document.querySelector('[data-toc-root]');
      if (!root) return null;
      var host = ensureHost();
      // 换页后旧节点可能还在 host 里
      host.innerHTML = '';
      host.appendChild(root);
      return root;
    }

    function applyHidden(hidden) {
      var article = getArticle();
      var panel = document.querySelector('[data-toc-panel]');
      var showBtn = document.querySelector('[data-toc-show]');
      if (!article) return;

      article.classList.toggle('toc-collapsed', hidden);
      document.documentElement.classList.toggle('toc-is-collapsed', hidden);
      document.documentElement.classList.toggle('toc-is-open', !hidden && !!panel);

      if (panel) {
        panel.setAttribute('aria-hidden', hidden ? 'true' : 'false');
        panel.hidden = !!hidden;
      }
      if (showBtn) {
        if (hidden) showBtn.removeAttribute('hidden');
        else showBtn.setAttribute('hidden', '');
      }
    }

    function initSpy() {
      var links = Array.from(document.querySelectorAll('#senmu-toc-fixed-host .toc a[href^="#"], [data-toc-root] .toc a[href^="#"]'));
      if (!links.length) return;

      var map = {};
      links.forEach(function (a) {
        var id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
        if (id) map[id] = a;
      });

      var heads = Object.keys(map)
        .map(function (id) {
          return document.getElementById(id);
        })
        .filter(Boolean);

      function setActive(id) {
        links.forEach(function (a) {
          a.classList.remove('is-active');
        });
        if (map[id]) map[id].classList.add('is-active');
      }

      if (window.__senmuTocObserver) {
        window.__senmuTocObserver.disconnect();
      }

      window.__senmuTocObserver = new IntersectionObserver(
        function (entries) {
          var visible = entries
            .filter(function (e) {
              return e.isIntersecting;
            })
            .sort(function (a, b) {
              return b.intersectionRatio - a.intersectionRatio;
            });
          if (visible[0] && visible[0].target && visible[0].target.id) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-20% 0px -65% 0px', threshold: [0, 0.25, 0.5, 1] },
      );

      heads.forEach(function (h) {
        window.__senmuTocObserver.observe(h);
      });
    }

    function initToc() {
      // 无目录文章：清掉残留宿主
      if (!getArticle()) {
        var old = document.getElementById(HOST_ID);
        if (old) old.innerHTML = '';
        document.documentElement.classList.remove('toc-is-open', 'toc-is-collapsed');
        return;
      }

      mountFixedUi();

      var hidden = false;
      try {
        hidden = localStorage.getItem(STORAGE_KEY) === '1';
      } catch (e) {}
      applyHidden(hidden);
      initSpy();
    }

    if (!window.__senmuTocToggleBound) {
      window.__senmuTocToggleBound = true;
      document.addEventListener(
        'click',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          if (t.closest('[data-toc-hide]')) {
            try {
              localStorage.setItem(STORAGE_KEY, '1');
            } catch (err) {}
            applyHidden(true);
          }
          if (t.closest('[data-toc-show]')) {
            try {
              localStorage.setItem(STORAGE_KEY, '0');
            } catch (err) {}
            applyHidden(false);
          }
        },
        true,
      );
    }

    initToc();
    document.addEventListener('astro:page-load', initToc);
    document.addEventListener('astro:after-swap', initToc);
  })();
</script>

<style is:global>
  /* 固定在视口左侧，不随文章滚动 */
  #senmu-toc-fixed-host {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 30;
    pointer-events: none;
    width: 0;
  }

  #senmu-toc-fixed-host .toc-root {
    pointer-events: none;
  }

  #senmu-toc-fixed-host .toc-panel,
  #senmu-toc-fixed-host .toc-show-btn {
    pointer-events: auto;
  }

  #senmu-toc-fixed-host .toc-panel {
    position: fixed;
    left: max(0.75rem, calc((100vw - 1100px) / 2));
    top: calc(var(--header-h, 64px) + 1rem);
    width: min(240px, calc(100vw - 2rem));
    max-height: calc(100vh - var(--header-h, 64px) - 2rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: var(--space-4);
  }

  #senmu-toc-fixed-host .toc-panel[hidden] {
    display: none !important;
  }

  #senmu-toc-fixed-host .toc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: var(--space-3);
  }

  #senmu-toc-fixed-host .toc-title {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  #senmu-toc-fixed-host .toc-hide-btn {
    border: 1px solid var(--border);
    background: var(--soft);
    color: var(--muted);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
  }

  #senmu-toc-fixed-host .toc-hide-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  #senmu-toc-fixed-host .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
  }

  #senmu-toc-fixed-host .toc-item a {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.4;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    border-left: 2px solid transparent;
    text-decoration: none;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  #senmu-toc-fixed-host .toc-item a:hover {
    color: var(--accent);
    background: var(--soft);
  }

  #senmu-toc-fixed-host .toc-item a.is-active {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: var(--soft);
  }

  #senmu-toc-fixed-host .toc-item.depth-3 {
    padding-left: 0.65rem;
  }

  #senmu-toc-fixed-host .toc-item.depth-3 a {
    font-size: 0.85rem;
  }

  /* 隐藏后：固定在左边的「显示目录」——始终贴视口左侧 */
  #senmu-toc-fixed-host .toc-show-btn {
    position: fixed;
    left: 0;
    top: 42%;
    z-index: 40;
    writing-mode: vertical-rl;
    letter-spacing: 0.15em;
    padding: 1rem 0.55rem;
    border-radius: 0 12px 12px 0;
    border: 1px solid var(--border);
    border-left: none;
    background: var(--accent);
    color: #fff;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow-hover);
  }

  #senmu-toc-fixed-host .toc-show-btn:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  #senmu-toc-fixed-host .toc-show-btn[hidden] {
    display: none !important;
  }

  /* 正文给左侧固定目录留空，避免重叠（桌面） */
  @media (min-width: 900px) {
    html.toc-is-open article.article.has-toc:not(.toc-collapsed) .article-layout {
      padding-left: 260px;
    }
  }

  @media (min-width: 1100px) {
    #senmu-toc-fixed-host .toc-panel {
      width: 250px;
    }

    html.toc-is-open article.article.has-toc:not(.toc-collapsed) .article-layout {
      padding-left: 280px;
    }
  }

  @media (max-width: 899px) {
    #senmu-toc-fixed-host .toc-panel {
      left: 0.75rem;
      right: 0.75rem;
      width: auto;
      top: calc(var(--header-h, 64px) + 0.5rem);
      max-height: min(42vh, 320px);
    }

    #senmu-toc-fixed-host .toc-show-btn {
      top: auto;
      bottom: 5.5rem;
      left: 0.85rem;
      writing-mode: horizontal-tb;
      letter-spacing: 0;
      padding: 0.65rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--border);
    }

    html.toc-is-open article.article.has-toc:not(.toc-collapsed) .article-layout {
      padding-left: 0;
      padding-top: 0;
    }
  }

  @media print {
    #senmu-toc-fixed-host {
      display: none !important;
    }
  }
</style>
