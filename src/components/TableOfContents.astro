---
import type { Heading } from '../lib/reading';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const show = headings.length >= 2;
---

{
  show && (
    <>
      <div class="toc-panel" id="toc-panel" data-toc-panel>
        <div class="toc-head">
          <p class="toc-title">目录</p>
          <button
            type="button"
            class="toc-hide-btn"
            data-toc-hide
            aria-controls="toc-panel"
            title="隐藏目录"
          >
            隐藏
          </button>
        </div>
        <nav class="toc" aria-label="文章目录">
          <ol class="toc-list">
            {headings.map((h) => (
              <li class:list={['toc-item', `depth-${h.depth}`]}>
                <a href={`#${h.id}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </div>

      <button
        type="button"
        class="toc-show-btn"
        data-toc-show
        aria-controls="toc-panel"
        title="显示目录"
        hidden
      >
        显示目录
      </button>
    </>
  )
}

<script is:inline>
  (function () {
    var STORAGE_KEY = 'senmu-toc-hidden';

    function getArticle() {
      return document.querySelector('article.article.has-toc');
    }

    function applyHidden(hidden) {
      var article = getArticle();
      var panel = document.querySelector('[data-toc-panel]');
      var showBtn = document.querySelector('[data-toc-show]');
      if (!article || !panel) return;

      article.classList.toggle('toc-collapsed', hidden);
      panel.setAttribute('aria-hidden', hidden ? 'true' : 'false');
      if (showBtn) {
        if (hidden) showBtn.removeAttribute('hidden');
        else showBtn.setAttribute('hidden', '');
      }
    }

    function initToc() {
      var article = getArticle();
      if (!article) return;

      var hideBtn = document.querySelector('[data-toc-hide]');
      var showBtn = document.querySelector('[data-toc-show]');

      var stored = false;
      try {
        stored = localStorage.getItem(STORAGE_KEY) === '1';
      } catch (e) {}
      applyHidden(stored);

      if (hideBtn && !hideBtn.dataset.bound) {
        hideBtn.dataset.bound = '1';
        hideBtn.addEventListener('click', function () {
          try {
            localStorage.setItem(STORAGE_KEY, '1');
          } catch (e) {}
          applyHidden(true);
        });
      }

      if (showBtn && !showBtn.dataset.bound) {
        showBtn.dataset.bound = '1';
        showBtn.addEventListener('click', function () {
          try {
            localStorage.setItem(STORAGE_KEY, '0');
          } catch (e) {}
          applyHidden(false);
        });
      }

      // 滚动高亮当前章节
      var links = Array.from(document.querySelectorAll('.toc a[href^="#"]'));
      if (links.length === 0) return;

      var map = {};
      links.forEach(function (a) {
        var id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
        if (id) map[id] = a;
      });

      var heads = Object.keys(map)
        .map(function (id) {
          return document.getElementById(id);
        })
        .filter(Boolean);

      function setActive(id) {
        links.forEach(function (a) {
          a.classList.remove('is-active');
        });
        if (map[id]) map[id].classList.add('is-active');
      }

      if (window.__senmuTocObserver) {
        window.__senmuTocObserver.disconnect();
      }

      window.__senmuTocObserver = new IntersectionObserver(
        function (entries) {
          var visible = entries
            .filter(function (e) {
              return e.isIntersecting;
            })
            .sort(function (a, b) {
              return b.intersectionRatio - a.intersectionRatio;
            });
          if (visible[0] && visible[0].target && visible[0].target.id) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-20% 0px -65% 0px', threshold: [0, 0.25, 0.5, 1] },
      );

      heads.forEach(function (h) {
        window.__senmuTocObserver.observe(h);
      });

      links.forEach(function (a) {
        a.addEventListener('click', function () {
          var id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
          if (id) setActive(id);
        });
      });
    }

    // 事件委托：兼容 View Transitions 换页
    if (!window.__senmuTocToggleBound) {
      window.__senmuTocToggleBound = true;
      document.addEventListener(
        'click',
        function (e) {
          var t = e.target;
          if (!t || !t.closest) return;
          if (t.closest('[data-toc-hide]')) {
            try {
              localStorage.setItem(STORAGE_KEY, '1');
            } catch (err) {}
            applyHidden(true);
          }
          if (t.closest('[data-toc-show]')) {
            try {
              localStorage.setItem(STORAGE_KEY, '0');
            } catch (err) {}
            applyHidden(false);
          }
        },
        true,
      );
    }

    initToc();
    document.addEventListener('astro:page-load', initToc);
    document.addEventListener('astro:after-swap', initToc);
  })();
</script>

<style>
  .toc-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    padding: var(--space-4);
    /* 页面滚动时，目录停在左侧不跟着走 */
    position: sticky;
    top: calc(var(--header-h) + 1rem);
    max-height: calc(100vh - var(--header-h) - 2rem);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .toc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: var(--space-3);
  }

  .toc-title {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .toc-hide-btn {
    border: 1px solid var(--border);
    background: var(--soft);
    color: var(--muted);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    white-space: nowrap;
  }

  .toc-hide-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
  }

  .toc-item a {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.4;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    border-left: 2px solid transparent;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--accent);
    background: var(--soft);
  }

  .toc-item a:global(.is-active) {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: var(--soft);
  }

  .toc-item.depth-3 {
    padding-left: 0.65rem;
  }

  .toc-item.depth-3 a {
    font-size: 0.85rem;
  }

  /* 隐藏后：屏幕左侧悬浮「显示目录」——固定在视口上，不随滚动消失 */
  .toc-show-btn {
    position: fixed;
    left: 0;
    top: 42%;
    z-index: 40;
    writing-mode: vertical-rl;
    letter-spacing: 0.15em;
    padding: 1rem 0.55rem;
    border-radius: 0 12px 12px 0;
    border: 1px solid var(--border);
    border-left: none;
    background: var(--accent);
    color: #fff;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow-hover);
  }

  .toc-show-btn:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  .toc-show-btn[hidden] {
    display: none !important;
  }

  @media (max-width: 899px) {
    .toc-panel {
      position: relative;
      top: auto;
      max-height: none;
      margin-bottom: 0;
    }

    .toc-show-btn {
      top: auto;
      bottom: 5.5rem;
      left: 0.85rem;
      writing-mode: horizontal-tb;
      letter-spacing: 0;
      padding: 0.65rem 1rem;
      border-radius: var(--radius-pill);
      border: 1px solid var(--border);
    }
  }

  @media print {
    .toc-panel,
    .toc-show-btn {
      display: none !important;
    }
  }
</style>
