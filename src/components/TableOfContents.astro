---
import type { Heading } from '../lib/reading';

interface Props {
  headings: Heading[];
  /** sidebar：左侧粘性；inline：正文上方（移动端） */
  variant?: 'sidebar' | 'inline';
}

const { headings, variant = 'sidebar' } = Astro.props;
const show = headings.length >= 2;
---

{
  show && (
    <nav class:list={['toc', `toc-${variant}`]} aria-label="文章目录">
      <p class="toc-title">目录</p>
      <ol class="toc-list">
        {headings.map((h) => (
          <li class:list={['toc-item', `depth-${h.depth}`]}>
            <a href={`#${h.id}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<script>
  function initTocSpy() {
    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.toc a[href^="#"]'),
    );
    if (links.length === 0) return;

    const map = new Map<string, HTMLAnchorElement>();
    links.forEach((a) => {
      const id = decodeURIComponent(a.getAttribute('href')?.slice(1) || '');
      if (id) map.set(id, a);
    });

    const headings = Array.from(map.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);

    if (headings.length === 0) return;

    const setActive = (id: string) => {
      links.forEach((a) => a.classList.remove('is-active'));
      map.get(id)?.classList.add('is-active');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible[0]?.target?.id) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-20% 0px -65% 0px',
        threshold: [0, 0.25, 0.5, 1],
      },
    );

    headings.forEach((h) => observer.observe(h));

    // 点击后立即高亮
    links.forEach((a) => {
      a.addEventListener('click', () => {
        const id = decodeURIComponent(a.getAttribute('href')?.slice(1) || '');
        if (id) setActive(id);
      });
    });
  }

  initTocSpy();
  document.addEventListener('astro:page-load', initTocSpy);
</script>

<style>
  .toc-title {
    margin: 0 0 var(--space-3);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15rem;
  }

  .toc-item a {
    display: block;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.4;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    border-left: 2px solid transparent;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--accent);
    background: var(--soft);
  }

  .toc-item a:global(.is-active) {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: var(--soft);
  }

  .toc-item.depth-3 {
    padding-left: 0.65rem;
  }

  .toc-item.depth-3 a {
    font-size: 0.85rem;
  }

  /* 左侧侧栏：桌面粘性 */
  .toc-sidebar {
    position: sticky;
    top: calc(var(--header-h) + 1rem);
    max-height: calc(100vh - var(--header-h) - 2rem);
    overflow-y: auto;
    padding: var(--space-4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  /* 移动端内联目录 */
  .toc-inline {
    margin: 0 0 var(--space-5);
    padding: var(--space-4);
    background: var(--soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
  }
</style>
