---
import type { Heading } from '../lib/reading';

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{
  headings.length >= 2 && (
    <nav class="toc" aria-label="文章目录">
      <p class="toc-title">目录</p>
      <ol class="toc-list">
        {headings.map((h) => (
          <li class:list={['toc-item', `depth-${h.depth}`]}>
            <a href={`#${h.id}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<style>
  .toc {
    max-width: var(--content-width);
    margin: 0 0 var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
  }

  .toc-title {
    margin: 0 0 var(--space-3);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
  }

  .toc-item a {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .toc-item a:hover {
    color: var(--accent);
  }

  .toc-item.depth-3 {
    padding-left: 1rem;
  }

  .toc-item.depth-3 a {
    font-size: 0.9rem;
    color: var(--muted);
  }
</style>
