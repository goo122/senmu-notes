---
import { categoryLabels, type Category } from '../lib/site';

interface Props {
  category: Category;
}

const { category } = Astro.props;
const label = categoryLabels[category];
---

<span class:list={['cat-badge', `cat-${category}`]}>{label}</span>

<style>
  .cat-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .cat-life {
    color: #c2410c;
  }

  .cat-notes {
    color: #b45309;
  }

  .cat-other {
    color: var(--muted);
  }

  :global(html.dark) .cat-life {
    color: #fdba74;
  }

  :global(html.dark) .cat-notes {
    color: #fbbf24;
  }
</style>
