---
import { site, nav } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

function isActive(href: string, path: string) {
  if (href === '/') return path === '/' || path === '';
  return path === href || path.startsWith(href + '/');
}
---

<header class="site-header">
  <div class="container header-inner">
    <a class="logo" href="/">{site.name}</a>
    <div class="header-right">
      <nav class="nav" id="site-nav" aria-label="主导航">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href, currentPath) }]}
              aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a class="icon-btn search-btn" href="/search" aria-label="搜索" title="搜索 (/)">⌕</a>
      <ThemeToggle />
      <button
        type="button"
        class="icon-btn menu-btn"
        id="menu-toggle"
        aria-label="打开菜单"
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <span class="menu-icon" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('site-nav');
  const header = document.querySelector('.site-header');

  function setOpen(open: boolean) {
    header?.classList.toggle('nav-open', open);
    toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle?.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');
  }

  toggle?.addEventListener('click', () => {
    setOpen(!header?.classList.contains('nav-open'));
  });

  nav?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: var(--header-h);
    background: var(--header-bg);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    min-height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .logo:hover {
    color: var(--accent);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.55rem;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.25rem 0.3rem;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--soft);
    color: var(--text);
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    text-decoration: none;
    padding: 0;
  }

  .icon-btn:hover {
    color: var(--accent);
  }

  .menu-btn {
    display: none;
  }

  .menu-icon,
  .menu-icon::before,
  .menu-icon::after {
    display: block;
    width: 1rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    position: relative;
    transition: transform 0.15s ease;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .menu-icon::before {
    top: -5px;
  }

  .menu-icon::after {
    top: 5px;
  }

  :global(.site-header.nav-open) .menu-icon {
    background: transparent;
  }

  :global(.site-header.nav-open) .menu-icon::before {
    top: 0;
    transform: rotate(45deg);
  }

  :global(.site-header.nav-open) .menu-icon::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (max-width: 760px) {
    .menu-btn {
      display: inline-flex;
    }

    .search-btn {
      display: none;
    }

    .nav {
      display: none;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1rem 1rem;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-soft);
    }

    :global(.site-header.nav-open) .nav {
      display: flex;
    }

    .nav-link {
      padding: 0.75rem 0.5rem;
      border-bottom: 1px solid var(--border);
      font-size: 1rem;
    }

    .nav-link:last-child {
      border-bottom: none;
    }
  }
</style>
