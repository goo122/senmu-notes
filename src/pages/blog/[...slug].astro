---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import PostNav from '../../components/PostNav.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Comments from '../../components/Comments.astro';
import CodeCopy from '../../components/CodeCopy.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TrackReading from '../../components/TrackReading.astro';
import {
  getNeighborPosts,
  getRelatedPosts,
  readingMinutesFor,
} from '../../lib/posts';
import { extractHeadings, formatReadingTime } from '../../lib/reading';
import { site } from '../../lib/site';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings: renderedHeadings } = await post.render();
const { prev, next } = await getNeighborPosts(post.slug);
const related = await getRelatedPosts(post, 3);
const minutes = readingMinutesFor(post);
const readingTime = formatReadingTime(minutes);

const headings =
  renderedHeadings && renderedHeadings.length > 0
    ? renderedHeadings
        .filter((h) => h.depth >= 2 && h.depth <= 3)
        .map((h) => ({ depth: h.depth, text: h.text, id: h.slug }))
    : extractHeadings(post.body);

const hasToc = headings.length >= 2;

const base = Astro.site ?? new URL(site.url);
const articleUrl = new URL(`/blog/${post.slug}`, base).toString();
const ogImagePath = post.data.heroImage
  ? post.data.heroImage
  : `/og/${post.slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: site.author,
  },
  mainEntityOfPage: articleUrl,
  inLanguage: site.lang,
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  wordCount: post.body.length,
  timeRequired: `PT${minutes}M`,
  image: new URL(ogImagePath, base).toString(),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImagePath}
  type="article"
  jsonLd={jsonLd}
  showProgress
  ogSlug={post.slug}
>
  <ReadingProgress slot="progress" />
  <TrackReading slug={post.slug} title={post.data.title} />
  <article class:list={['container', 'article', { 'has-toc': hasToc }]}>
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <PostMeta
        pubDate={post.data.pubDate}
        category={post.data.category}
        tags={post.data.tags}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
      />
      <ShareBar title={post.data.title} />
    </header>

    <div class="article-layout">
      {
        hasToc && (
          <aside class="toc-col" aria-label="文章目录">
            <TableOfContents headings={headings} />
          </aside>
        )
      }

      <div class="article-main">
        <div class="prose">
          <Content />
        </div>
        <CodeCopy />
        <PostNav prev={prev} next={next} />
        <RelatedPosts posts={related} />
        <Comments />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article.has-toc.container {
    width: min(100% - 2rem, 1100px);
    max-width: 1100px;
  }

  .article-header {
    margin-bottom: var(--space-5);
  }

  .article-header h1 {
    margin: 0 0 var(--space-4);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.25;
    max-width: var(--content-width);
  }

  .article.has-toc .article-header h1 {
    max-width: none;
  }

  .article-layout {
    display: block;
  }

  /* 移动端：目录在正文上方 */
  .toc-col {
    margin-bottom: var(--space-5);
  }

  .article-main {
    min-width: 0;
  }

  .article-main :global(.prose) {
    margin-inline: 0;
    max-width: var(--content-width);
  }

  .article-main :global(.post-nav),
  .article-main :global(.related),
  .article-main :global(.comments),
  .article :global(.post-meta),
  .article :global(.share-bar) {
    max-width: var(--content-width);
  }

  /*
   * 桌面：左目录 + 右正文
   * align-items: stretch 让左侧列与正文同高，
   * 这样 sticky 目录在下滑读正文时会固定在视口左侧。
   */
  @media (min-width: 900px) {
    .article.has-toc .article-layout {
      display: grid;
      grid-template-columns: 240px minmax(0, 1fr);
      gap: var(--space-8);
      align-items: stretch;
    }

    .toc-col {
      margin-bottom: 0;
      min-height: 100%;
    }

    /* 收起目录后正文占满 */
    .article.has-toc.toc-collapsed .article-layout {
      grid-template-columns: 1fr;
    }

    .article.has-toc.toc-collapsed .toc-col {
      display: none;
    }
  }

  @media (min-width: 1100px) {
    .article.has-toc:not(.toc-collapsed) .article-layout {
      grid-template-columns: 260px minmax(0, 1fr);
    }
  }

  /* 移动端收起：隐藏面板，保留悬浮按钮 */
  @media (max-width: 899px) {
    .article.has-toc.toc-collapsed .toc-col :global([data-toc-panel]) {
      display: none;
    }
  }

  @media print {
    .toc-col {
      display: none !important;
    }

    .article.has-toc .article-layout {
      display: block;
    }
  }
</style>
