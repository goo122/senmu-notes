---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import PostNav from '../../components/PostNav.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Comments from '../../components/Comments.astro';
import CodeCopy from '../../components/CodeCopy.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import TrackReading from '../../components/TrackReading.astro';
import {
  getNeighborPosts,
  getRelatedPosts,
  readingMinutesFor,
} from '../../lib/posts';
import { extractHeadings, formatReadingTime } from '../../lib/reading';
import { site } from '../../lib/site';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings: renderedHeadings } = await post.render();
const { prev, next } = await getNeighborPosts(post.slug);
const related = await getRelatedPosts(post, 3);
const minutes = readingMinutesFor(post);
const readingTime = formatReadingTime(minutes);

const headings =
  renderedHeadings && renderedHeadings.length > 0
    ? renderedHeadings
        .filter((h) => h.depth >= 2 && h.depth <= 3)
        .map((h) => ({ depth: h.depth, text: h.text, id: h.slug }))
    : extractHeadings(post.body);

const base = Astro.site ?? new URL(site.url);
const articleUrl = new URL(`/blog/${post.slug}`, base).toString();
const ogImagePath = post.data.heroImage
  ? post.data.heroImage
  : `/og/${post.slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: site.author,
  },
  mainEntityOfPage: articleUrl,
  inLanguage: site.lang,
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  wordCount: post.body.length,
  timeRequired: `PT${minutes}M`,
  image: new URL(ogImagePath, base).toString(),
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImagePath}
  type="article"
  jsonLd={jsonLd}
  showProgress
  ogSlug={post.slug}
>
  <ReadingProgress slot="progress" />
  <TrackReading slug={post.slug} title={post.data.title} />
  <article class="container article">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <PostMeta
        pubDate={post.data.pubDate}
        category={post.data.category}
        tags={post.data.tags}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
      />
      <ShareBar title={post.data.title} />
    </header>
    <TableOfContents headings={headings} />
    <div class="prose">
      <Content />
    </div>
    <CodeCopy />
    <PostNav prev={prev} next={next} />
    <RelatedPosts posts={related} />
    <Comments />
  </article>
</BaseLayout>

<style>
  .article-header h1 {
    margin: 0 0 var(--space-4);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.25;
    max-width: var(--content-width);
  }

  .article :global(.post-meta),
  .article :global(.post-nav),
  .article :global(.toc),
  .article :global(.share-bar),
  .article :global(.related),
  .article :global(.comments) {
    max-width: var(--content-width);
  }
</style>
