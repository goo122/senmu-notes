---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import PostNav from '../../components/PostNav.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getNeighborPosts, readingMinutesFor } from '../../lib/posts';
import { extractHeadings, formatReadingTime } from '../../lib/reading';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content, headings: renderedHeadings } = await post.render();
const { prev, next } = await getNeighborPosts(post.slug);
const readingTime = formatReadingTime(readingMinutesFor(post));

// Prefer Astro-rendered heading ids; fallback to markdown parse
const headings =
  renderedHeadings && renderedHeadings.length > 0
    ? renderedHeadings
        .filter((h) => h.depth >= 2 && h.depth <= 3)
        .map((h) => ({ depth: h.depth, text: h.text, id: h.slug }))
    : extractHeadings(post.body);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  type="article"
>
  <article class="container article">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <PostMeta
        pubDate={post.data.pubDate}
        category={post.data.category}
        tags={post.data.tags}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
      />
    </header>
    <TableOfContents headings={headings} />
    <div class="prose">
      <Content />
    </div>
    <PostNav prev={prev} next={next} />
  </article>
</BaseLayout>

<style>
  .article-header h1 {
    margin: 0 0 var(--space-4);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    line-height: 1.25;
    max-width: var(--content-width);
  }

  .article :global(.post-meta),
  .article :global(.post-nav),
  .article :global(.toc) {
    max-width: var(--content-width);
  }
</style>
