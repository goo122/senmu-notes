---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import {
  getPublishedPosts,
  getCategoryCounts,
} from '../../../lib/posts';
import { getTotalPages, paginateItems, POSTS_PER_PAGE } from '../../../lib/pagination';
import { site, categoryLabels, type Category } from '../../../lib/site';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = getTotalPages(posts.length, POSTS_PER_PAGE);
  // page 1 is /blog; only emit 2..N
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageNum = Number(Astro.params.page);
const allPosts = await getPublishedPosts();
const { items, page, totalPages, total, prevHref, nextHref } = paginateItems(
  allPosts,
  pageNum,
);

const counts = await getCategoryCounts();
const countMap = new Map(counts.map((c) => [c.category, c.count]));
const categories = (Object.keys(categoryLabels) as Category[]).filter(
  (c) => (countMap.get(c) ?? 0) > 0,
);
---

<BaseLayout
  title={`文章 · 第 ${page} 页`}
  description={`全部文章第 ${page} 页 — ${site.name}`}
>
  <div class="container">
    <header class="page-header">
      <h1>文章</h1>
      <p class="lead">
        共 {total} 篇 · 第 {page}/{totalPages} 页
      </p>
    </header>

    {
      categories.length > 0 && (
        <div class="filters" role="navigation" aria-label="按分类筛选">
          <a class="filter active" href="/blog">
            全部 <span class="n">{total}</span>
          </a>
          {categories.map((cat) => (
            <a class="filter" href={`/categories/${cat}`}>
              {categoryLabels[cat]} <span class="n">{countMap.get(cat)}</span>
            </a>
          ))}
        </div>
      )
    }

    <div class="post-list">
      {items.map((post) => <PostCard post={post} />)}
    </div>

    <Pagination
      page={page}
      totalPages={totalPages}
      prevHref={prevHref}
      nextHref={nextHref}
    />
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-5);
  }

  .page-header h1 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
  }

  .lead {
    margin: 0;
    color: var(--muted);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-6);
  }

  .filter {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .filter:hover,
  .filter.active {
    color: #9a3412;
    background: var(--soft);
  }

  :global(html.dark) .filter:hover,
  :global(html.dark) .filter.active {
    color: var(--accent);
  }

  .filter .n {
    font-weight: 500;
    color: var(--muted);
  }

  .post-list {
    display: grid;
    gap: var(--space-4);
  }
</style>
