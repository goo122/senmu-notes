---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostsByCategory, getCategoryCounts } from '../../lib/posts';
import { site, categoryLabels, type Category } from '../../lib/site';

export async function getStaticPaths() {
  const counts = await getCategoryCounts();
  return counts.map(({ category }) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const cat = category as Category;
const label = categoryLabels[cat] ?? cat;
const posts = await getPostsByCategory(cat);
const available = (await getCategoryCounts()).map((c) => c.category);
---

<BaseLayout title={`${label} · 分类`} description={`${label}分类下的文章 — ${site.name}`}>
  <div class="container">
    <header class="page-header">
      <p class="eyebrow"><a href="/blog">← 全部文章</a></p>
      <h1>{label}</h1>
      <p class="lead">{posts.length} 篇文章</p>
    </header>

    <div class="filters" role="navigation" aria-label="分类">
      <a class="filter" href="/blog">全部</a>
      {
        available.map((c) => (
          <a class:list={['filter', { active: c === cat }]} href={`/categories/${c}`}>
            {categoryLabels[c]}
          </a>
        ))
      }
    </div>

    {
      posts.length === 0 ? (
        <p class="empty-state">暂无文章</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-5);
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
  }

  .page-header h1 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
  }

  .lead {
    margin: 0;
    color: var(--muted);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-6);
  }

  .filter {
    display: inline-flex;
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .filter:hover,
  .filter.active {
    color: #9a3412;
    background: var(--soft);
  }

  :global(html.dark) .filter:hover,
  :global(html.dark) .filter.active {
    color: var(--accent);
  }

  .post-list {
    display: grid;
    gap: var(--space-4);
  }
</style>
