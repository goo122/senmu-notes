---
/** 网页发文后台 */
export const prerender = true;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>写文章 · 森木笔记</title>
    <style>
      html,
      body {
        margin: 0;
        min-height: 100%;
        font-family: system-ui, 'PingFang SC', 'Microsoft YaHei', sans-serif;
        background: #fffdf9;
      }
      #boot {
        max-width: 34rem;
        margin: 12vh auto;
        padding: 1.5rem;
        color: #44403c;
        line-height: 1.65;
      }
      #boot h1 {
        margin: 0 0 0.75rem;
        font-size: 1.35rem;
        color: #1c1917;
      }
      #boot.hidden {
        display: none !important;
      }
      #boot.error {
        border: 1px solid #fecaca;
        background: #fef2f2;
        border-radius: 12px;
      }
      #boot code {
        background: #fff7ed;
        padding: 0.1em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
      }
      #boot pre {
        background: #1c1917;
        color: #fafaf9;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        overflow: auto;
        font-size: 0.85rem;
        white-space: pre-wrap;
      }
      #boot a {
        color: #ea580c;
      }
    </style>
    <!-- 必须在 CMS 脚本之前设置，禁止自动初始化 -->
    <script is:inline>
      window.CMS_MANUAL_INIT = true;
    </script>
  </head>
  <body>
    <div id="boot">
      <h1>正在加载发文后台…</h1>
      <p id="status">准备中…</p>
      <p>
        请使用 <code>npm run write</code> 启动，并用<strong>终端里显示的端口</strong>打开
        <code>/admin</code>。
      </p>
      <p>例如：<code>http://127.0.0.1:4330/admin</code></p>
      <p><a href="/write">发文说明</a> · <a href="/">回首页</a></p>
    </div>

    <script is:inline>
      (function () {
        var boot = document.getElementById('boot');
        var statusEl = document.getElementById('status');

        function status(msg) {
          if (statusEl) statusEl.textContent = msg;
        }

        function fail(title, detail) {
          boot.classList.add('error');
          boot.innerHTML =
            '<h1>' +
            title +
            '</h1><p>' +
            detail +
            '</p><pre id="err"></pre><p><a href="/write">说明</a> · <button type="button" onclick="location.reload()">刷新重试</button></p>';
          if (arguments[2]) {
            boot.querySelector('#err').textContent = arguments[2];
          }
        }

        function loadScript(src) {
          return new Promise(function (resolve, reject) {
            var s = document.createElement('script');
            s.src = src;
            s.onload = function () {
              resolve(src);
            };
            s.onerror = function () {
              reject(new Error('加载失败: ' + src));
            };
            document.body.appendChild(s);
          });
        }

        var config = {
          local_backend: true,
          backend: {
            name: 'git-gateway',
            branch: 'feature/personal-blog',
          },
          media_folder: 'public/uploads',
          public_folder: '/uploads',
          collections: [
            {
              name: 'posts',
              label: '文章',
              label_singular: '文章',
              folder: 'src/content/posts',
              create: true,
              delete: true,
              slug: '{{slug}}',
              extension: 'md',
              format: 'frontmatter',
              fields: [
                { label: '标题', name: 'title', widget: 'string' },
                { label: '摘要', name: 'description', widget: 'text' },
                {
                  label: '发布日期',
                  name: 'pubDate',
                  widget: 'datetime',
                  date_format: 'YYYY-MM-DD',
                  time_format: false,
                  format: 'YYYY-MM-DD',
                },
                {
                  label: '更新日期',
                  name: 'updatedDate',
                  widget: 'datetime',
                  date_format: 'YYYY-MM-DD',
                  time_format: false,
                  format: 'YYYY-MM-DD',
                  required: false,
                },
                {
                  label: '分类',
                  name: 'category',
                  widget: 'select',
                  options: [
                    { label: '技术', value: 'tech' },
                    { label: '生活', value: 'life' },
                    { label: '随想', value: 'notes' },
                    { label: '其他', value: 'other' },
                  ],
                  default: 'notes',
                },
                { label: '标签', name: 'tags', widget: 'list', required: false },
                {
                  label: '首页精选',
                  name: 'featured',
                  widget: 'boolean',
                  default: false,
                  required: false,
                },
                {
                  label: '草稿',
                  name: 'draft',
                  widget: 'boolean',
                  default: false,
                  required: false,
                },
                {
                  label: '封面图',
                  name: 'heroImage',
                  widget: 'image',
                  required: false,
                },
                { label: '正文', name: 'body', widget: 'markdown' },
              ],
            },
          ],
        };

        async function start() {
          status('正在加载 CMS 脚本（jsDelivr）…');
          var sources = [
            'https://cdn.jsdelivr.net/npm/decap-cms@3.3.3/dist/decap-cms.js',
            'https://unpkg.com/decap-cms@3.3.3/dist/decap-cms.js',
          ];
          var ok = false;
          var err;
          for (var i = 0; i < sources.length; i++) {
            try {
              await loadScript(sources[i]);
              ok = true;
              status('已加载: ' + sources[i]);
              break;
            } catch (e) {
              err = e;
            }
          }

          if (!ok) {
            fail(
              'CMS 脚本加载失败',
              '无法从 CDN 下载 decap-cms。请检查网络/代理后刷新。',
              err && err.message,
            );
            return;
          }

          if (typeof window.CMS === 'undefined') {
            fail('CMS 未定义', '脚本已下载但 window.CMS 不存在，可能是版本或 CDN 内容异常。');
            return;
          }

          status('正在初始化编辑器…');
          try {
            window.CMS.init({
              config: config,
            });
          } catch (e) {
            fail('初始化失败', e.message || String(e), e.stack);
            return;
          }

          // 最多等 12 秒，看到 nc-root 或明显的 CMS 节点再隐藏 boot
          var n = 0;
          var t = setInterval(function () {
            n++;
            var mounted =
              document.getElementById('nc-root') ||
              document.querySelector('[class*="nc-']') ||
              document.querySelector('div[class*="App"]');
            if (mounted) {
              clearInterval(t);
              boot.classList.add('hidden');
              return;
            }
            if (n >= 48) {
              clearInterval(t);
              // 有时 class 名变了但已渲染：body 子元素增多则认为成功
              if (document.body.childElementCount > 1) {
                boot.classList.add('hidden');
              } else {
                fail(
                  '界面未渲染',
                  '请按 F12 打开 Console 查看红色报错。并确认终端里 cms 进程显示 listening on port 8081。',
                );
              }
            }
          }, 250);
        }

        start();
      })();
    </script>
  </body>
</html>
